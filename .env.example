COUCHDB_URL=http://localhost:5984
COUCHDB_DATABASE=orgsync
COUCHDB_USER=admin
COUCHDB_PASSWORD=password
DEVICE_ID=org-syncd
LOCAL_DIR=/data/org
POLL_INTERVAL=5s
DRY_RUN=false
INCLUDE_EXTS=.org,.md,.txt
IGNORE=.git,.DS_Store,*.tmp
LOG_LEVEL=info
HOST=0.0.0.0
PORT=8080
MCP_AUTH_TOKEN=replace-with-a-long-random-token
BASE_URL=https://org-vault.example.com
DATA_DIR=/data/org-syncd
MCP_REFRESH_DAYS=14
